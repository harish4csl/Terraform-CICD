pipeline {
    agent any

    stages {
        stage('clone') {
            steps {
              git branch: "main", url: 'https://github.com/harish4csl/Tearrform-009PM-practice.git'
            }
        }
        stage('init') {
            steps {
                sh 'terraform init'
            }
        }
         stage('plan') {
            steps {
                sh 'terraform plan'
            }
        }
    }
}
